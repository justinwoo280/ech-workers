# Internal planning docs — never commit to public repo
# UUID-prefixed files (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-*.md)
tickets/
[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]-[0-9a-f][0-9a-f][0-9a-f][0-9a-f]-*.md

# .NET
**/bin/
**/obj/
**/.vs/
**/*.user
**/*.suo

# VS Code
**/.vscode/

# Build outputs
/build/
**/publish/

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Go build artifacts — never commit binaries
# (cleaned 197MB → 1.8MB by git-filter-repo on 2026-04-27;
#  any pattern below is a learned mistake from v1 history)
# Match only repo-root binaries, not paths containing these names!
# (the ewp-core/ source tree has thousands of files matching ewp-*)
*.exe
*.out
/ech-workers
/ech-workers-*
/proxy-server
/proxy-server-*
/ewp-server
/ewp-client
/ewp                       # cmd/ewp v2 binary
/ewp-server-*
/ewp-client-*
/ewp-relay
/ewp-cli
/*-linux
/*-macos
/*-windows
/*-darwin
/*-freebsd
/test-*
**/cmd/*/ewp                # cmd/ewp/ewp binary inside subdirs
**/cmd/*/test-*

# Backup directories created by git-filter-repo or manual rm
.git.bak
.git.bak-*

# DLL files (except wintun.dll which is a required runtime dependency)
*.dll
!ewp-core/wintun.dll

# Build artefacts (CMake / Gradle / gomobile)
**/build/
**/.gradle/
**/local.properties
**/*.aar
**/*.jar
!ewp-android/app/libs/.gitkeep
!ewp-android/gradle/wrapper/gradle-wrapper.jar
ewp-core/output/

# IDE
.idea/
.vscode/
*.iml
