<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>EditNodeDialog</class>
 <widget class="QDialog" name="EditNodeDialog">
  <property name="windowTitle"><string>编辑节点</string></property>
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>520</width><height>540</height></rect>
  </property>
  <layout class="QVBoxLayout" name="rootLayout">

   <!-- 基本 -->
   <item>
    <widget class="QGroupBox" name="basicGroup">
     <property name="title"><string>基本</string></property>
     <layout class="QFormLayout" name="basicForm">
      <item row="0" column="0"><widget class="QLabel"><property name="text"><string>名称</string></property></widget></item>
      <item row="0" column="1"><widget class="QLineEdit" name="editName"/></item>

      <item row="1" column="0"><widget class="QLabel"><property name="text"><string>服务器地址</string></property></widget></item>
      <item row="1" column="1">
       <layout class="QHBoxLayout">
        <item><widget class="QLineEdit" name="editAddress"/></item>
        <item>
         <widget class="QSpinBox" name="spinPort">
          <property name="minimum"><number>1</number></property>
          <property name="maximum"><number>65535</number></property>
          <property name="value"><number>443</number></property>
         </widget>
        </item>
       </layout>
      </item>

      <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Host (可选)</string></property></widget></item>
      <item row="2" column="1"><widget class="QLineEdit" name="editHost"><property name="placeholderText"><string>留空则同服务器地址</string></property></widget></item>

      <item row="3" column="0"><widget class="QLabel"><property name="text"><string>SNI (可选)</string></property></widget></item>
      <item row="3" column="1"><widget class="QLineEdit" name="editSNI"><property name="placeholderText"><string>留空则回退 Host → 服务器地址</string></property></widget></item>
     </layout>
    </widget>
   </item>

   <!-- 认证 -->
   <item>
    <widget class="QGroupBox" name="authGroup">
     <property name="title"><string>认证</string></property>
     <layout class="QHBoxLayout">
      <item><widget class="QLabel"><property name="text"><string>UUID</string></property></widget></item>
      <item><widget class="QLineEdit" name="editUUID"/></item>
      <item><widget class="QPushButton" name="btnGenerateUUID"><property name="text"><string>随机</string></property></widget></item>
     </layout>
    </widget>
   </item>

   <!-- 传输 -->
   <item>
    <widget class="QGroupBox" name="transportGroup">
     <property name="title"><string>传输</string></property>
     <layout class="QVBoxLayout">
      <item>
       <widget class="QComboBox" name="comboTransport">
        <item><property name="text"><string>WebSocket</string></property></item>
        <item><property name="text"><string>gRPC</string></property></item>
        <item><property name="text"><string>XHTTP</string></property></item>
        <item><property name="text"><string>H3gRPC</string></property></item>
       </widget>
      </item>

      <item>
       <widget class="QGroupBox" name="wsGroup">
        <property name="title"><string>WebSocket 配置</string></property>
        <layout class="QFormLayout">
         <item row="0" column="0"><widget class="QLabel"><property name="text"><string>路径</string></property></widget></item>
         <item row="0" column="1"><widget class="QLineEdit" name="editWsPath"><property name="text"><string>/ewp</string></property></widget></item>
        </layout>
       </widget>
      </item>

      <item>
       <widget class="QGroupBox" name="grpcGroup">
        <property name="title"><string>gRPC / H3gRPC 配置</string></property>
        <layout class="QFormLayout">
         <item row="0" column="0"><widget class="QLabel"><property name="text"><string>服务名</string></property></widget></item>
         <item row="0" column="1"><widget class="QLineEdit" name="editGrpcService"><property name="text"><string>ProxyService</string></property></widget></item>
        </layout>
       </widget>
      </item>

      <item>
       <widget class="QGroupBox" name="xhttpGroup">
        <property name="title"><string>XHTTP 配置</string></property>
        <layout class="QFormLayout">
         <item row="0" column="0"><widget class="QLabel"><property name="text"><string>路径</string></property></widget></item>
         <item row="0" column="1"><widget class="QLineEdit" name="editXHTTPPath"><property name="text"><string>/xhttp</string></property></widget></item>
        </layout>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- ECH 与 DNS -->
   <item>
    <widget class="QGroupBox" name="echGroup">
     <property name="title"><string>ECH 与 DNS</string></property>
     <layout class="QFormLayout">
      <item row="0" column="0"><widget class="QLabel"><property name="text"><string>启用 ECH</string></property></widget></item>
      <item row="0" column="1">
       <widget class="QCheckBox" name="checkEnableECH">
        <property name="text"><string>加密 ClientHello,隐藏 SNI</string></property>
        <property name="checked"><bool>true</bool></property>
       </widget>
      </item>
      <item row="1" column="0"><widget class="QLabel"><property name="text"><string>ECH 查询域名</string></property></widget></item>
      <item row="1" column="1">
       <widget class="QLineEdit" name="editECHDomain">
        <property name="placeholderText"><string>留空: 自动用 SNI/服务器地址 | Cloudflare 用户填: cloudflare-ech.com</string></property>
        <property name="toolTip"><string>HTTPS RR 查询域名 — 集中式 ECH 服务 (如 Cloudflare) 把 ECH 公钥发布在独立公共域名上, 与你的实际后端无关. 自托管 ECH 留空即可.</string></property>
       </widget>
      </item>
      <item row="2" column="0"><widget class="QLabel"><property name="text"><string>DoH 服务器</string></property></widget></item>
      <item row="2" column="1">
       <widget class="QLineEdit" name="editDoHServers">
        <property name="placeholderText"><string>逗号分隔; 留空走内置默认 (AliDNS / DNSPod)</string></property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>

   <!-- OK / Cancel -->
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation"><enum>Qt::Horizontal</enum></property>
     <property name="standardButtons">
      <set>QDialogButtonBox::Ok|QDialogButtonBox::Cancel</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections>
  <connection>
   <sender>buttonBox</sender>
   <signal>accepted()</signal>
   <receiver>EditNodeDialog</receiver>
   <slot>accept()</slot>
  </connection>
  <connection>
   <sender>buttonBox</sender>
   <signal>rejected()</signal>
   <receiver>EditNodeDialog</receiver>
   <slot>reject()</slot>
  </connection>
 </connections>
</ui>
