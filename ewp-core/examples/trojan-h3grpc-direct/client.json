{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1:30000",
      "udp": true
    }
  ],
  "outbounds": [
    {
      "type": "trojan",
      "tag": "proxy-out",
      "server": "your.domain.com",
      "server_port": 443,
      "password": "your-strong-password-here",
      "transport": {
        "type": "h3grpc",
        "service_name": "laowangopc"
      },
      "tls": {
        "enabled": true,
        "server_name": "your.domain.com",
        "insecure": false,
        "alpn": ["h3"]
      }
    }
  ],
  "route": {
    "final": "proxy-out",
    "auto_detect_interface": true
  }
}
